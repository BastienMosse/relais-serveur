# Copiez ce fichier en ".env" pour un test local de server.js.
# Sur Render, ne pas utiliser ce fichier : renseignez ces mêmes variables
# dans l'onglet "Environment" du service (PORT est géré par Render lui-même,
# ne pas le définir manuellement là-bas).

PORT=8080

# Identifiant + mot de passe pour le dashboard de monitoring (obligatoires
# pour y accéder — sans ADMIN_TOKEN, 401 systématique).
# ADMIN_USER est optionnel : "admin" par défaut si absent.
ADMIN_USER=admin
# Choisissez une valeur longue et aléatoire pour ADMIN_TOKEN, par exemple
# générée avec : openssl rand -hex 24
ADMIN_TOKEN=change-moi-avec-une-valeur-aleatoire-longue

# Optionnel : persistance de l'état (identities/links/pending) entre les
# mises en veille sur le plan gratuit Render, via Upstash Redis (gratuit,
# sans CB). Sans ces deux variables, l'état est perdu à chaque veille.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=